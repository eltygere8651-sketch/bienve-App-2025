rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas específicas para el Portal del Cliente (acceso mediante enlace compartido sin login)
    // Permite lectura de datos de cliente y préstamos si se conoce el ID exacto
    match /clients/{clientId} {
      allow get: if true; 
      allow list: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /loans/{loanId} {
      allow read: if true; 
      allow write: if request.auth != null;
    }
    
    // Acceso restringido por defecto solo a administradores autenticados para lo demás
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
